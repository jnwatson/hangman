# Rate limiting: 10 requests/sec per IP with burst allowance.
limit_req_zone $binary_remote_addr zone=api:10m rate=10r/s;
# Connection limiting: max concurrent connections per IP.
limit_conn_zone $binary_remote_addr zone=perip:10m;

# --- Default server (IP-only access) ---
server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;

    root /opt/dead-letters/static;
    index index.html;
    server_tokens off;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /api/ {
        limit_req zone=api burst=30 nodelay;
        limit_conn perip 20;

        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

        proxy_connect_timeout 5s;
        proxy_send_timeout 5s;
        proxy_read_timeout 15s;
    }
}

# --- HTTPS server ---
server {
    server_name www.deadletters.fun deadletters.fun;

    root /opt/dead-letters/static;
    index index.html;
    server_tokens off;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /api/ {
        limit_req zone=api burst=30 nodelay;
        limit_conn perip 20;

        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

        proxy_connect_timeout 5s;
        proxy_send_timeout 5s;
        proxy_read_timeout 15s;
    }

    listen [::]:443 ssl ipv6only=on; # managed by Certbot
    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/deadletters.fun/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/deadletters.fun/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot
}

# --- HTTP → HTTPS redirect ---
server {
    if ($host = www.deadletters.fun) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    if ($host = deadletters.fun) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    listen 80;
    listen [::]:80;
    server_name www.deadletters.fun deadletters.fun;
    return 404; # managed by Certbot
}
